pipeline{
    agent any
     tools {
            maven 'Maven3'
        }
    stages{
        stage("Clean Up"){
            steps{
                deleteDir()
            }
        }
        stage("Clone Repo"){
            steps{
                sh "git clone https://github.com/rahulrsr10/automationFramework.git"
            }
        }
        stage("Build"){
            steps{
                dir("automationFramework"){
                    sh "mvn clean install"
                }
            }
        }
        stage("Test"){
           steps{
            echo "Job Tested"
           }
        }
    }
}